# Database (used by both Prisma Client at runtime and prisma.config.ts for the CLI)
DATABASE_URL="postgresql://neondb_owner:npg_UdCXDn1OVjN5@ep-proud-frog-atpvowyg-pooler.c-9.us-east-1.aws.neon.tech/neondb?sslmode=verify-full&channel_binding=require"

# Paystack
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxx"
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxx"

# Auth (Auth.js v5 — credentials/email+password for now, Google can be added later)
# Generate AUTH_SECRET with: pnpm dlx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3005"

# Web Push (VAPID keys for push notifications — generate with `pnpm dlx web-push generate-vapid-keys`)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@sellersplace.app"

# Store branding (per-client customization)
NEXT_PUBLIC_STORE_NAME="SellersPlace"
NEXT_PUBLIC_STORE_PRIMARY_COLOR="#DC2626"
