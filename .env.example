# Database (used by both Prisma Client at runtime and prisma.config.ts for the CLI)
# Local Postgres:
DATABASE_URL="postgresql://user:password@localhost:5432/sellersplace?schema=public"
# Neon (copy the pooled connection string from the Neon console — keep sslmode=require):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-your-endpoint-pooler.region.aws.neon.tech/neondb?sslmode=require"
# NEVER commit a real connection string to this file — it is checked into git.

# Paystack
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxx"
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxx"

# Auth (Auth.js v5 — credentials/email+password for now, Google can be added later)
# Generate AUTH_SECRET with: pnpm dlx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3005"

# Web Push (VAPID keys for push notifications — generate with `pnpm dlx web-push generate-vapid-keys`)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@sellersplace.app"

# Canonical public origin — drives SEO metadata, canonical URLs, sitemap,
# robots.txt, and JSON-LD. REQUIRED in production or search URLs point at
# localhost. No trailing slash.
NEXT_PUBLIC_SITE_URL="http://localhost:3005"

# Store branding (per-client customization)
NEXT_PUBLIC_STORE_NAME="SellersPlace"
NEXT_PUBLIC_STORE_PRIMARY_COLOR="#DC2626"
# Optional logo image URL — replaces the wordmark icon in the header and feeds
# Organization JSON-LD. Falls back to the generated brand icon when unset.
# NEXT_PUBLIC_STORE_LOGO="https://res.cloudinary.com/.../logo.png"

# Home hero media (ad/campaign slot). Priority: video → image → first product
# image → typographic hero. Any image URL works; video should be mp4/webm.
# NEXT_PUBLIC_STORE_HERO_VIDEO="https://videos.pexels.com/video-files/.../....mp4"
# NEXT_PUBLIC_STORE_HERO_IMAGE="https://res.cloudinary.com/.../campaign.jpg"
# NEXT_PUBLIC_STORE_HERO_HREF="/products"

# Support-chat LLM tier (optional — FAQ + agent escalation work without it).
# The first configured key wins, in order: Anthropic → OpenAI → Gemini → Mistral.
# SUPPORT_LLM_PROVIDER="anthropic"   # optional: force one of anthropic|openai|gemini|mistral
# SUPPORT_LLM_MODEL=""               # optional model override (e.g. claude-haiku-4-5)
# ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""
# GEMINI_API_KEY=""
# MISTRAL_API_KEY=""

# What kind of brand this deployment serves — drives storefront vocabulary
# (nav labels, hero copy, search placeholder, Cart vs Bookings).
# One of: retail | services | hybrid   (defaults to retail when unset)
NEXT_PUBLIC_STORE_KIND="retail"

# Contact channels for chat-to-order offerings (PurchaseMode CONTACT_SELLER/BOTH
# and quote-priced items). Without these, contact-only items show a
# "contact details not configured" notice instead of chat/call buttons.
# WhatsApp number in international format WITHOUT the leading "+":
NEXT_PUBLIC_STORE_WHATSAPP="2348012345678"
# Phone number for the "Call" button (any tel:-dialable format):
NEXT_PUBLIC_STORE_PHONE="+2348012345678"

# Fulfilment wordmark on product cards (the "JUMIA EXPRESS" pattern).
# Shown on directly-buyable physical products; hidden when unset.
NEXT_PUBLIC_STORE_EXPRESS_BADGE="SELLERSPLACE EXPRESS"

# Seed overrides (optional — defaults are admin@sellersplace.app / changeme123;
# always change the password before any real deployment)
# SEED_ADMIN_EMAIL="admin@yourstore.com"
# SEED_ADMIN_PASSWORD="a-strong-password"

# Cloudinary (product image uploads from the admin dashboard — free tier at
# cloudinary.com; find these on your Cloudinary console dashboard)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
