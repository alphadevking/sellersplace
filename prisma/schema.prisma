generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String?
  phone             String?
  passwordHash      String?
  role              Role               @default(CUSTOMER)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  isGuest           Boolean            @default(false)
  addresses         Address[]
  orders            Order[]
  pushSubscriptions PushSubscription[]
  wishlist          WishlistItem[]
  inquiries         Inquiry[]
  reviews           Review[]
  conversation      Conversation?
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String?
  fullName  String
  phone     String
  line1     String
  line2     String?
  city      String
  state     String
  country   String   @default("Nigeria")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  imageUrl  String?
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id             String           @id @default(cuid())
  name           String
  slug           String           @unique
  description    String?
  brand          String?
  /// Jumia-style specifications shown on the product page, e.g. {"Material": "Leather"}.
  attributes     Json?
  /// This template serves both retail and service brands: an offering is either
  /// a physical PRODUCT (stock, delivery) or a SERVICE (booking/inquiry, no stock).
  offeringType   OfferingType     @default(PRODUCT)
  /// FIXED shows the price as-is; FROM shows "From ₦X" (tiered/estimated work);
  /// QUOTE hides the price entirely — buyers must contact the seller.
  priceType      PriceType        @default(FIXED)
  purchaseMode   PurchaseMode     @default(PAY_ONLINE)
  /// When set (1–99), online checkout charges this % upfront and the balance
  /// is collected later — common for services and made-to-order work.
  depositPercent Int?
  /// Denormalized review aggregates, refreshed whenever a review is saved.
  ratingAvg      Decimal?         @db.Decimal(3, 2)
  ratingCount    Int              @default(0)
  price          Decimal          @db.Decimal(12, 2)
  compareAtPrice Decimal?         @db.Decimal(12, 2)
  images         String[]
  stock          Int              @default(0)
  sku            String?          @unique
  isActive       Boolean          @default(true)
  categoryId     String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  orderItems     OrderItem[]
  category       Category?        @relation(fields: [categoryId], references: [id])
  variants       ProductVariant[]
  wishlistItems  WishlistItem[]
  inquiries      Inquiry[]
  reviews        Review[]

  // Trigram indexes for the typo-tolerant fuzzy search stage (pg_trgm).
  @@index([name(ops: raw("gin_trgm_ops"))], map: "Product_name_trgm_idx", type: Gin)
  @@index([brand(ops: raw("gin_trgm_ops"))], map: "Product_brand_trgm_idx", type: Gin)
}

/// Verified-buyer product review; aggregates are cached on Product.
model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  rating    Int
  body      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
}

model ProductVariant {
  id        String      @id @default(cuid())
  productId String
  /// Display name, e.g. "Red / XL" or "128GB".
  name      String
  sku       String?     @unique
  /// Overrides the parent product price when set.
  price     Decimal?    @db.Decimal(12, 2)
  stock     Int         @default(0)
  /// Structured option values, e.g. {"color": "Red", "size": "XL"}.
  options   Json?
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Order {
  id            String             @id @default(cuid())
  orderNumber   String             @unique
  userId        String
  addressId     String?
  /// Preferred date/time for service bookings (service-only orders skip shipping).
  serviceDate   DateTime?
  /// Free-text note from the customer at checkout (e.g. booking details).
  customerNote  String?
  subtotal      Decimal            @db.Decimal(12, 2)
  deliveryFee   Decimal            @default(0) @db.Decimal(12, 2)
  total         Decimal            @db.Decimal(12, 2)
  /// Sum of successful payments so far (deposits, balance, invoice payments).
  amountPaid    Decimal            @default(0) @db.Decimal(12, 2)
  /// Admin-issued invoice for quoted/bespoke work (created from an inquiry).
  isInvoice     Boolean            @default(false)
  /// Unguessable token for sharing invoice pay links with customers.
  accessToken   String?            @unique
  status        OrderStatus        @default(PENDING)
  paymentStatus PaymentStatus      @default(PENDING)
  paystackRef   String?            @unique
  /// True once this order's confirmation decremented inventory — guards
  /// against double-decrementing (deposit then balance) and enables restore
  /// on cancellation.
  stockAdjusted Boolean            @default(false)
  /// Shipment tracking, set by admin at dispatch.
  carrier        String?
  trackingNumber String?
  trackingUrl    String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  address       Address?           @relation(fields: [addressId], references: [id])
  user          User               @relation(fields: [userId], references: [id])
  items         OrderItem[]
  payments      Payment[]
  statusHistory OrderStatusEvent[]
}

/// One Paystack transaction against an order. Orders can have several
/// (deposit → balance), so the webhook resolves payments by reference.
model Payment {
  id        String        @id @default(cuid())
  orderId   String
  reference String        @unique
  amount    Decimal       @db.Decimal(12, 2)
  kind      PaymentKind
  status    PaymentTxStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  /// Null for custom invoice lines that don't map to a catalog item.
  productId   String?
  variantId   String?
  /// Snapshot of the variant name at purchase time (variants can be renamed/deleted).
  variantName String?
  /// Line title for custom invoice items (used when productId is null).
  titleOverride String?
  quantity    Int
  unitPrice   Decimal         @db.Decimal(12, 2)
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product?        @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
}

model OrderStatusEvent {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

/// A chat/quote request for a contact-mode offering. Captures WhatsApp clicks
/// and inquiry-form submissions so leads are tracked in admin, not just fired
/// into an external chat app.
model Inquiry {
  id          String         @id @default(cuid())
  productId   String?
  userId      String?
  /// Variant/tier the customer was looking at, snapshotted as text.
  variantName String?
  name        String?
  /// Email or phone the customer wants to be reached on (form inquiries).
  contact     String?
  message     String?
  channel     InquiryChannel @default(FORM)
  status      InquiryStatus  @default(NEW)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  product     Product?       @relation(fields: [productId], references: [id], onDelete: SetNull)
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
}

/// Aggregated log of storefront searches — powers "trending searches" and
/// future ranking signals. One row per normalized term.
model SearchQuery {
  id             String   @id @default(cuid())
  /// Lowercased, whitespace-collapsed search term.
  term           String   @unique
  count          Int      @default(1)
  lastSearchedAt DateTime @default(now())
  createdAt      DateTime @default(now())
}

/// One in-app support thread per customer (reopened rather than duplicated).
/// Messages are TLS-in-transit + at-rest encrypted, NOT end-to-end — the store
/// must read them to reply. WhatsApp remains the E2E channel.
model Conversation {
  id              String             @id @default(cuid())
  userId          String             @unique
  status          ConversationStatus @default(OPEN)
  /// Denormalized for inbox ordering without joining messages.
  lastMessageAt   DateTime           @default(now())
  /// Read cursors per side — anything newer counts as unread for that side.
  userLastReadAt  DateTime           @default(now())
  adminLastReadAt DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        ChatMessage[]
  tickets         Ticket[]

  @@index([status, lastMessageAt])
}

model ChatMessage {
  id             String       @id @default(cuid())
  conversationId String
  sender         ChatSender
  /// Which admin/staff account authored a STORE message.
  senderUserId   String?
  /// The ticket that was active when this message was sent, if any — gives
  /// each support issue its own auditable slice of the thread.
  ticketId       String?
  body           String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  ticket         Ticket?      @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
}

/// A trackable support issue inside a chat thread. Escalating to a human opens
/// one; the conversation is "with an agent" while it has an unresolved ticket.
/// Minimal on purpose — categories/assignees/SLAs are additive later.
model Ticket {
  id             String       @id @default(cuid())
  /// Customer-facing reference, e.g. "TKT-M9X2K1" (same scheme as invoices).
  number         String       @unique
  conversationId String
  status         TicketStatus @default(OPEN)
  /// CSAT, collected after resolution: 5 = thumbs-up, 1 = thumbs-down
  /// (int-scaled so a 1–5 star upgrade needs no migration).
  rating         Int?
  ratingComment  String?
  openedAt       DateTime     @default(now())
  resolvedAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messages       ChatMessage[]

  @@index([status, openedAt])
  @@index([conversationId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  CUSTOMER
  ADMIN
  STAFF
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum ChatSender {
  CUSTOMER
  STORE
  /// Automated FAQ/assistant replies — always labeled as such in the UI.
  BOT
}

/// How a product can be bought: straight online payment, by contacting the
/// seller (chat/negotiate — common for high-touch or bespoke businesses), or both.
enum PurchaseMode {
  PAY_ONLINE
  CONTACT_SELLER
  BOTH
}

enum OfferingType {
  PRODUCT
  SERVICE
}

enum InquiryChannel {
  WHATSAPP
  PHONE
  FORM
}

enum InquiryStatus {
  NEW
  RESPONDED
  CLOSED
}

enum PriceType {
  FIXED
  FROM
  QUOTE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  FAILED
  REFUNDED
}

enum PaymentKind {
  FULL
  DEPOSIT
  BALANCE
  INVOICE
}

enum PaymentTxStatus {
  PENDING
  SUCCESS
}
